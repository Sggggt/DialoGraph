APP_NAME=Course Knowledge Base API
APP_ENV=development
APP_PORT=8000
API_IMAGE=course-kg-api:local
WEB_IMAGE=course-kg-web:local

# Docker Compose host ports
API_HOST_PORT=8000
WEB_HOST_PORT=3000
MODEL_BRIDGE_ENABLED=false
MODEL_BRIDGE_PORT=8765
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/course_kg
ENABLE_DATABASE_FALLBACK=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_chunks
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_KEYS=
COURSE_NAME=Sample Course
DATA_ROOT=./data
# Course files default to DATA_ROOT/<course>/storage and DATA_ROOT/<course>/ingestion.
# Avoid global STORAGE_ROOT/INGESTION_ROOT in Docker multi-course runs.
# STORAGE_ROOT=./data/Sample Course/storage
# INGESTION_ROOT=./data/Sample Course/ingestion
OPENAI_API_KEY=
CHAT_BASE_URL=
CHAT_RESOLVE_IP=

# Embedding model may use a different provider / endpoint from chat model.
# EMBEDDING_BASE_URL is required for real embedding calls and never falls back to CHAT_BASE_URL.
EMBEDDING_BASE_URL=
EMBEDDING_RESOLVE_IP=
EMBEDDING_API_KEY=

EMBEDDING_MODEL=
EMBEDDING_BATCH_SIZE=10
CHAT_MODEL=
EMBEDDING_DIMENSIONS=1024
GRAPH_EXTRACTION_CHUNK_LIMIT=72
GRAPH_EXTRACTION_CHUNKS_PER_DOCUMENT=2
ENABLE_MODEL_FALLBACK=false

# Chunk+Embedding Enhancement
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_MAX_LENGTH=512

# HuggingFace Hub offline mode avoids network retries on startup when the model is already cached.
# Set to 1 if you are behind a firewall or experiencing slow container startup.
HF_HUB_OFFLINE=1

# Semantic Chunking
SEMANTIC_CHUNKING_ENABLED=true
SEMANTIC_CHUNKING_MIN_LENGTH=2000

# Retrieval Layering
RETRIEVAL_LAYER_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=300

# Agentic RAG
ENABLE_AGENTIC_REFLECTION=true
ENABLE_POST_GENERATION_REFLECTION=false
CITATION_VERIFICATION_SAMPLE_MAX=3
REFLECTION_MAX_RETRIES=2

# Incremental Graph
INCREMENTAL_GRAPH_ENABLED=true
