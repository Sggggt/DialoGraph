APP_NAME=Course Knowledge Base API
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/course_kg
ENABLE_DATABASE_FALLBACK=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_chunks
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_KEYS=
COURSE_NAME=Sample Course
DATA_ROOT=./data
# STORAGE_ROOT=./data/Sample Course/storage
# INGESTION_ROOT=./data/Sample Course/ingestion
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_RESOLVE_IP=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BATCH_SIZE=10
CHAT_MODEL=qwen-plus
EMBEDDING_DIMENSIONS=1024
GRAPH_EXTRACTION_CHUNK_LIMIT=72
GRAPH_EXTRACTION_CHUNKS_PER_DOCUMENT=2
ENABLE_MODEL_FALLBACK=false
